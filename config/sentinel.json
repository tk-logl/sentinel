{
  "language": "auto",
  "source_extensions": [
    "py",
    "ts",
    "tsx",
    "js",
    "jsx",
    "go",
    "rs",
    "java",
    "c",
    "cpp",
    "svelte",
    "vue"
  ],
  "skip_patterns": [
    "**/test_*",
    "**/*.test.*",
    "**/*.spec.*",
    "**/tests/**",
    "**/__pycache__/**",
    "**/node_modules/**",
    "**/.sentinel/**",
    "**/.claude/**",
    "**/.omc/**"
  ],
  "enforcement": {
    "pre_edit_gate": true,
    "deny_dummy": true,
    "surgical_change": true,
    "scope_guard": true,
    "secret_scan": true,
    "file_header_check": true,
    "env_safety": true,
    "error_logger": true,
    "post_edit_verify": true,
    "completion_check": true,
    "scope_reduction_guard": true,
    "task_scope_guard": true,
    "task_automark": true,
    "task_completion_gate": true,
    "subagent_context": true
  },
  "header_threshold_lines": 200,
  "error_repeat_limit": 3,
  "surgical_change_max_lines": 15,
  "taskList": {
    "enabled": true,
    "file": "auto",
    "idPattern": "[A-Z]+-[0-9]+",
    "states": {
      "pending": "- [ ]",
      "inProgress": "- [~]",
      "done": "- [x]"
    },
    "autoMarkOnCommit": true,
    "injectOnSessionStart": true,
    "injectOnPostCompact": true,
    "maxInjectItems": 30
  },
  "preImplGate": {
    "taskFile": ".sentinel/current-task.json",
    "requiredFields": [
      "item_id",
      "why",
      "approach",
      "impact_files",
      "blast_radius",
      "verify_command"
    ],
    "injectSpecOnAllow": true
  },
  "mode": "standard",
  "protected_branches": [
    "main",
    "master",
    "develop"
  ],
  "_schema_version": "1.5.0",
  "_categories_schema": {
    "_comment": "Per-item overrides go in .sentinel/config.json under categories.{category}.{item_key}",
    "example": {
      "codeQuality": {
        "block_todo_comments": "off"
      },
      "safetyNet": {
        "block_push_protected_branch": "block"
      }
    },
    "linters": "Array of linter configs: {command, extensions, name}. Use {file} placeholder."
  },
  "linters": [
    {
      "command": "ruff check {file}",
      "extensions": [
        "py"
      ],
      "name": "ruff"
    }
  ]
}